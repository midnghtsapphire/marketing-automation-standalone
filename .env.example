# Marketing Automation Standalone - Environment Variables
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_APP=website_integration.py
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-random-secret-key

# Server
HOST=0.0.0.0
PORT=5000

# Database
AFFILIATE_DB_PATH=affiliate_links.db
MARKETING_DB_PATH=marketing_automation.db
SCHEDULER_DB_PATH=scheduler.db

# Browser Automation
SELENIUM_HEADLESS=true
CHROME_DRIVER_PATH=

# Social Media Accounts (encrypted in production)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
FACEBOOK_USERNAME=
FACEBOOK_PASSWORD=
TWITTER_USERNAME=
TWITTER_PASSWORD=
LINKEDIN_USERNAME=
LINKEDIN_PASSWORD=
TIKTOK_USERNAME=
TIKTOK_PASSWORD=
PINTEREST_USERNAME=
PINTEREST_PASSWORD=

# TikTok Integration (Blue Ocean)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# Email Campaign Builder (Blue Ocean)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_NAME=Audrey Evans
EMAIL_FROM_ADDRESS=

# Affiliate Configuration
AMAZON_AFFILIATE_TAG=audreyevans-20
SHOPIFY_STORE_URL=https://qahwacoffeebeans.com
SHOPIFY_AFFILIATE_ID=

# Content Generation
OPENAI_API_KEY=

# Scheduling
SCHEDULER_TIMEZONE=America/New_York
DEFAULT_POST_TIMES=09:00,12:00,17:00,20:00

# Logging
LOG_LEVEL=INFO
